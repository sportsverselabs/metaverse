# ─────────────────────────────────────────────────────────────
# Sportsverse OS — Environment Template
#
# HOW TO USE:
#   1. Copy this file and rename the copy to ".env"  (no real secrets in .env.example)
#   2. Fill in the real values in .env on your LOCAL machine only
#   3. NEVER commit .env. It is already listed in .gitignore.
#
# Every variable below is OPTIONAL right now — Phase 0 needs none of them.
# They are placeholders for future phases. See docs/api_keys_needed.md.
# ─────────────────────────────────────────────────────────────

# --- Core / runtime ---
SPORTSVERSE_ENV=local            # local | vps | production
LOG_LEVEL=info                   # debug | info | warn | error

# --- AI / LLM provider (only if agents call an AI model via API) ---
# LLM_MODE controls whether real models are called:
#   mock = default, NO network calls, offline placeholder responses (safe)
#   live = call a real provider (only works if the matching key below is set)
LLM_MODE=mock
# Choose the provider(s) you actually use; leave the rest blank.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
# Optional: override the default provider used in live mode (anthropic | openai | deepseek)
# LLM_PROVIDER=anthropic

# --- NVIDIA Nemotron / NeMo (optional; complex reasoning only) ---
# Leave disabled to use DeepSeek for everything. Nemotron is OpenAI-compatible via NIM,
# so it reuses the `openai` SDK pointed at NEMOTRON_BASE_URL.
NEMOTRON_ENABLED=false
NEMOTRON_API_KEY=
NEMOTRON_BASE_URL=
NEMOTRON_MODEL=

# --- Messaging (only if Sportsverse uses chat automation) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Email (only if the system sends email) ---
EMAIL_ADDRESS=
EMAIL_APP_PASSWORD=
SMTP_HOST=
SMTP_PORT=587

# --- Sports data sources (only when a data API is chosen) ---
SPORTS_DATA_API_KEY=
SPORTS_DATA_BASE_URL=

# --- Database / storage (only when persistence is added) ---
DATABASE_URL=

# --- Deployment / VPS (only at deployment time) ---
VPS_HOST=
VPS_USER=

# ─────────────────────────────────────────────────────────────
# Add new variables here as integrations are added.
# Document each one in docs/api_keys_needed.md.
# ─────────────────────────────────────────────────────────────
